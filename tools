local SearchTab = Window:CreateTab("Search", "search")
SearchTab:CreateSection("Search Pets")

local searchInput = SearchTab:CreateInput({
    Name = "Search Pet",
    CurrentValue = "",
    PlaceholderText = "e.g. Rainbow Bee",
    RemoveTextAfterFocusLost = false,
    Flag = "SearchInput",
    Callback = function(_) end,
})

local searchDropdown = SearchTab:CreateDropdown({
    Name = "Results",
    Options = {},
    CurrentOption = {},
    MultipleOptions = false,
    Flag = "SearchDropdown",
    Callback = function(_) end,
})

SearchTab:CreateButton({
    Name = "Search",
    Callback = function()
        local query = (searchInput.CurrentValue or ""):lower()
        local results = {}
        for _, name in ipairs(pets) do
            if name:lower():find(query, 1, true) then results[#results + 1] = name end
        end
        if #results == 0 then
            Rayfield:Notify({
                Title = "No Results",
                Content = "No pets matched: " .. (searchInput.CurrentValue or ""),
                Duration = 3,
                Image = "search-x",
            })
        else
            searchDropdown:Refresh(results)
            searchDropdown:Set({results[1]})
            Rayfield:Notify({
                Title = "Found " .. #results .. " pet(s)",
                Content = "Select one from the Results dropdown, then click Spawn.",
                Duration = 4,
                Image = "list",
            })
        end
    end,
})

SearchTab:CreateButton({
    Name = "Spawn Selected",
    Callback = function()
        local selected = searchDropdown.CurrentOption
        if selected and selected[1] and selected[1] ~= "" then
            spawnPet(selected[1])
        else
            Rayfield:Notify({
                Title = "Nothing Selected",
                Content = "Search for a pet first, then select it from the Results list.",
                Duration = 4,
                Image = "alert-circle",
            })
        end
    end,
})

