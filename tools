local function getSmartIcon(petName)
    local gear = ReplicatedStorage:FindFirstChild("SharedModules")
        and ReplicatedStorage.SharedModules:FindFirstChild("GearImages")
    if not gear then return "" end
    local variations = {
        petName,
        petName:gsub(" ", ""),
        petName:gsub("Big ", ""),
        petName:gsub("Mega ", ""),
        petName:gsub("Rainbow ", ""),
        "Normal " .. petName,
        petName:gsub("Serpent", " Serpent"),
        petName:gsub("Dragonfly", " Dragonfly"),
        petName:gsub("Big Rainbow ", ""),
        petName:gsub("Mega Rainbow ", ""),
    }
    for _, name in ipairs(variations) do
        local icon = gear:FindFirstChild(name)
        if icon and icon:IsA("StringValue") and icon.Value ~= "" then
            return icon.Value
        end
    end
    local base = petName:gsub("Big ", ""):gsub("Mega ", ""):gsub("Rainbow ", "")
    local icon = gear:FindFirstChild(base)
    if icon and icon:IsA("StringValue") and icon.Value ~= "" then
        return icon.Value
    end
    return ""
end

local function spawnPet(fullName)
    local base = fullName
    local size = "Normal"
    local pType = "Normal"

    if fullName:find("Mega Rainbow ") then
        size, pType, base = "Huge", "Rainbow", fullName:gsub("Mega Rainbow ", "")
    elseif fullName:find("Big Rainbow ") then
        size, pType, base = "Big", "Rainbow", fullName:gsub("Big Rainbow ", "")
    elseif fullName:find("Mega ") then
        size, base = "Huge", fullName:gsub("Mega ", "")
    elseif fullName:find("Big ") then
        size, base = "Big", fullName:gsub("Big ", "")
    end

    if pType == "Normal" and base:find("Rainbow ") then
        pType = "Rainbow"
        base = base:gsub("Rainbow ", "")
    end

    local modelName = base:gsub(" ", "")
    local petsFolder = ReplicatedStorage:FindFirstChild("Assets")
        and ReplicatedStorage.Assets:FindFirstChild("Pets")
    local model = petsFolder and petsFolder:FindFirstChild(modelName)

    if not model then
        Rayfield:Notify({
            Title = "Spawn Failed",
            Content = "Model not found: " .. modelName,
            Duration = 4,
            Image = "alert-circle",
        })
        return
    end

    local tool = Instance.new("Tool")
    tool.Name = fullName
    tool.RequiresHandle = true

    local icon = getSmartIcon(modelName)
    if icon == "" then icon = getSmartIcon(fullName) end
    if icon ~= "" then tool.TextureId = icon end

    local clone = model:Clone()
    tool:SetAttribute("Pet", modelName)
    tool:SetAttribute("PetSize", size)
    if pType == "Rainbow" then
        tool:SetAttribute("PetType", "Rainbow")
    end

    if clone.PrimaryPart then
        clone.PrimaryPart.Name = "Handle"
        clone.PrimaryPart.Parent = tool
        clone.Parent = tool
    else
        clone.Name = "Handle"
        clone.Parent = tool
    end

    tool.Parent = LocalPlayer.Backpack

    Rayfield:Notify({
        Title = "Pet Spawned!",
        Content = fullName .. " has been added to your backpack.",
        Duration = 3,
        Image = "paw-print",
    })
end

local function filterPets(predicate)
    local result = {}
    for _, name in ipairs(pets) do
        if predicate(name) then result[#result + 1] = name end
    end
    return result
end

local function isNormal(name)     return not name:find("Big ") and not name:find("Mega ") and not name:find("Rainbow ") end
local function isRainbow(name)    return name:find("Rainbow ") and not name:find("Big ") and not name:find("Mega ") end
local function isBig(name)        return name:find("Big ") and not name:find("Rainbow ") end
local function isBigRainbow(name) return name:find("Big Rainbow ") end
local function isMega(name)       return name:find("Mega ") and not name:find("Rainbow ") end
local function isMegaRainbow(name) return name:find("Mega Rainbow ") end

